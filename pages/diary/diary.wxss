page {
  background: #F2EBDD;
  color: #24231f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.paper-canvas,
.paper-texture {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.paper-canvas {
  z-index: 0;
  background: #F2EBDD;
}

.paper-texture {
  z-index: 0;
  opacity: 0.026;
}

.page {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100vh;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.hero {
  padding: calc(env(safe-area-inset-top) + 112rpx) 18rpx 36rpx;
}

.hero-eyebrow {
  display: block;
  color: #81776b;
  font-size: 19rpx;
  line-height: 1;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  color: #24231f;
  font-size: 60rpx;
  line-height: 1.05;
  font-weight: 700;
  letter-spacing: -3rpx;
}

.hero-summary {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  color: #746c62;
  font-size: 25rpx;
  line-height: 1.45;
}

.hero-summary > text:first-child {
  flex: 1;
}

.hero-count {
  flex-shrink: 0;
  color: #315c4b;
  font-size: 22rpx;
  font-weight: 650;
}

.surface-shell {
  margin-bottom: 22rpx;
  padding: 7rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.34);
  border: 1rpx solid rgba(65, 55, 43, 0.07);
  box-shadow: 0 12rpx 38rpx rgba(64, 48, 31, 0.035);
  box-sizing: border-box;
}

.surface-core {
  border-radius: 21rpx;
  background: rgba(253, 250, 244, 0.91);
  border: 1rpx solid rgba(65, 55, 43, 0.055);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.publish-card,
.diary-list-card {
  padding: 26rpx;
}

.section-header {
  margin-bottom: 28rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  display: block;
  color: #292722;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  color: #827a70;
  font-size: 22rpx;
  line-height: 1.45;
}

.section-index {
  color: #b7aa99;
  font-size: 21rpx;
  line-height: 1;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  color: #655e55;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.form-optional {
  margin-bottom: 10rpx;
  color: #a09689;
  font-size: 20rpx;
}

.field-control {
  width: 100%;
  height: 78rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  border-radius: 14rpx;
  background: rgba(238, 232, 222, 0.7);
  border: 1rpx solid rgba(64, 55, 44, 0.055);
  box-sizing: border-box;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background-color 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.field-control-hover {
  transform: scale(0.992);
  background: rgba(232, 225, 214, 0.84);
}

.picker {
  justify-content: space-between;
  gap: 20rpx;
}

.field-value,
.form-input {
  flex: 1;
  min-width: 0;
  color: #302d28;
  font-size: 26rpx;
  line-height: 1.3;
}

.form-input {
  width: 100%;
  height: 76rpx;
}

.field-placeholder {
  color: #a79d91;
}

.field-action {
  flex-shrink: 0;
  color: #315c4b;
  font-size: 22rpx;
  font-weight: 650;
}

.photo-field {
  margin-top: 4rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.image-item,
.image-add {
  width: 180rpx;
  height: 180rpx;
  border-radius: 15rpx;
  box-sizing: border-box;
}

.image-item {
  border: 1rpx solid rgba(64, 55, 44, 0.06);
}

.image-add {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  background: rgba(239, 233, 223, 0.66);
  border: 1rpx dashed rgba(80, 68, 54, 0.18);
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), opacity 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.image-add-hover {
  transform: scale(0.98);
  opacity: 0.76;
}

.image-add-title {
  color: #3d3933;
  font-size: 24rpx;
  font-weight: 650;
}

.image-add-sub {
  margin-top: 5rpx;
  color: #978d80;
  font-size: 19rpx;
}

.publish-btn {
  width: 100% !important;
  height: 84rpx !important;
  min-height: 84rpx !important;
  margin: 30rpx 0 0 !important;
  padding: 0 24rpx !important;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #292722;
  color: #fffdf8;
  font-size: 27rpx;
  line-height: 1 !important;
  font-weight: 650;
  box-sizing: border-box !important;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background-color 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.publish-btn::after {
  border: 0;
}

.publish-btn:active {
  transform: scale(0.985);
  background: #3b3832;
}

.form-notes {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #999084;
  font-size: 19rpx;
  line-height: 1.5;
}

.history-header {
  margin-bottom: 20rpx;
}

.history-count {
  flex-shrink: 0;
  color: #315c4b;
  font-size: 22rpx;
  font-weight: 650;
}

.diary-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.diary-item {
  padding: 22rpx;
  border-radius: 16rpx;
  background: rgba(248, 242, 232, 0.78);
  border: 1rpx solid rgba(64, 55, 44, 0.065);
}

.diary-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.diary-title-group {
  flex: 1;
  min-width: 0;
}

.diary-date {
  display: block;
  color: #968c7f;
  font-size: 19rpx;
  line-height: 1;
  font-weight: 550;
  letter-spacing: 1rpx;
}

.diary-title {
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  color: #2d2a25;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.diary-delete {
  flex-shrink: 0;
  padding: 4rpx 0 10rpx 18rpx;
  color: #b95d50;
  font-size: 21rpx;
  font-weight: 600;
}

.diary-images {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.diary-image {
  width: 148rpx;
  height: 148rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(64, 55, 44, 0.06);
}

.diary-meta {
  margin-top: 18rpx;
  padding-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  border-top: 1rpx solid rgba(64, 55, 44, 0.07);
}

.meta-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.meta-label {
  width: 58rpx;
  flex-shrink: 0;
  color: #958b7e;
  font-size: 20rpx;
  line-height: 1.5;
}

.meta-value {
  flex: 1;
  color: #625b52;
  font-size: 22rpx;
  line-height: 1.5;
}

.empty-state {
  padding: 32rpx 12rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-state-image {
  width: 176rpx;
  height: 176rpx;
  opacity: 0.7;
}

.empty-state-title {
  margin-top: 16rpx;
  color: #34312c;
  font-size: 29rpx;
  font-weight: 700;
}

.empty-state-desc {
  margin-top: 8rpx;
  color: #827a70;
  font-size: 22rpx;
}

.page-spacer {
  height: calc(env(safe-area-inset-bottom) + 180rpx);
}

.section-enter {
  animation: section-enter 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.section-delay-1 {
  animation-delay: 70ms;
}

.section-delay-2 {
  animation-delay: 140ms;
}

@keyframes section-enter {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  visibility: hidden;
  background: rgba(38, 34, 29, 0.42);
  opacity: 0;
  transition: opacity 520ms cubic-bezier(0.32, 0.72, 0, 1), visibility 520ms cubic-bezier(0.32, 0.72, 0, 1);
}

.modal-mask.active {
  visibility: visible;
  opacity: 1;
}

.recipe-selector {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 101;
  max-height: 72vh;
  border-radius: 34rpx 34rpx 0 0;
  background: #fbf6ed;
  border-top: 1rpx solid rgba(64, 55, 44, 0.08);
  box-shadow: 0 -20rpx 60rpx rgba(55, 44, 31, 0.08);
  transform: translateY(100%);
  transition: transform 620ms cubic-bezier(0.32, 0.72, 0, 1);
}

.recipe-selector.active {
  transform: translateY(0);
}

.recipe-selector-header {
  padding: 30rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid rgba(64, 55, 44, 0.08);
}

.recipe-selector-title {
  display: block;
  color: #2d2a25;
  font-size: 32rpx;
  font-weight: 700;
}

.recipe-selector-sub {
  display: block;
  margin-top: 7rpx;
  color: #8c8377;
  font-size: 21rpx;
}

.recipe-selector-close {
  flex-shrink: 0;
  color: #315c4b;
  font-size: 23rpx;
  font-weight: 650;
}

.recipe-grid {
  max-height: 58vh;
  padding: 24rpx 28rpx calc(env(safe-area-inset-bottom) + 30rpx);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  overflow-y: auto;
}

.recipe-card {
  min-height: 82rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-radius: 13rpx;
  background: rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(64, 55, 44, 0.075);
  box-sizing: border-box;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background-color 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.recipe-card-hover {
  transform: scale(0.99);
}

.recipe-card.selected {
  background: #e5ece2;
  border-color: rgba(49, 92, 75, 0.22);
}

.recipe-card-index {
  width: 42rpx;
  flex-shrink: 0;
  color: #9c9183;
  font-size: 19rpx;
  font-weight: 600;
}

.recipe-card.selected .recipe-card-index {
  color: #315c4b;
}

.recipe-card-name {
  overflow: hidden;
  color: #34312c;
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}
