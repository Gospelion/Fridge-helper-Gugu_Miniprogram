.bg-image {
  position: fixed; /* 固定定位，覆盖整个屏幕 */
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* 确保它在内容下方 */
  pointer-events: none; /* 防止阻挡点击事件 */
}

.page {
  padding: 24rpx;
  padding-bottom: 140rpx;  /* 为底部 tabBar 留出空间 */
  
  min-height: 100vh;
  box-sizing: border-box;
}

.publish-card {
  margin-bottom: 24rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.section-sub {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999999;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 26rpx;
  color: #555555;
  margin-bottom: 6rpx;
  display: block;
}

.form-input {
  background-color: #f7f7f7;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
}

.picker {
  background-color: #f7f7f7;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #333333;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-direction: row;
}

.picker text {
  display: inline-block;
  white-space: nowrap;
}

/* 图片上传区域 */
.image-list {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  border: 1rpx dashed #cccccc;
  justify-content: center;
  align-items: center;
  display: flex;
  color: #999999;
  font-size: 60rpx;
}

.publish-btn {
  margin-top: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #000000;
  line-height: 1.4;
  white-space: nowrap;
}

.hint-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #bbbbbb;
}

/* 日记列表 */
.diary-list-card {
  margin-top: 8rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.diary-list {
  margin-top: 8rpx;
}

.diary-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.diary-item:last-child {
  border-bottom-width: 0;
}

.diary-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.diary-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.diary-date {
  font-size: 22rpx;
  color: #999999;
}

.diary-content {
  display: flex;
  flex-direction: row;
  margin-top: 12rpx;
}

.diary-meta {
  font-size: 24rpx;
  color: #777777;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-start;
  margin-left: auto;
  padding-left: 16rpx;
}

.diary-images {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.diary-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}
.empty-state-hover { opacity: 0.72; }

.empty-state-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-state-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #555;
  margin-bottom: 12rpx;
}

.empty-state-desc {
  display: block;
  font-size: 28rpx;
  color: #888;
}

/* Picker 箭头 */
.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
  margin-left: 10rpx;
}

/* 模态框遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.modal-mask.active {
  opacity: 1;
  visibility: visible;
}

/* 菜名选择器 */
.recipe-selector {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.recipe-selector.active {
  transform: translateY(0);
}

.recipe-selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.recipe-selector-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.recipe-selector-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.recipe-selector-close text {
  font-size: 32rpx;
  color: #999999;
}

/* 菜名网格 */
.recipe-grid {
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.recipe-card {
  width: calc(33.33% - 12rpx);
  background-color: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.recipe-card.selected {
  background-color: #e8f5e9;
  border-color: #4caf50;
}

.recipe-card-name {
  font-size: 28rpx;
  color: #333333;
}

.diary-header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.diary-delete {
  color: #d9534f;
  font-size: 24rpx;
  padding: 8rpx 0 8rpx 12rpx;
}
