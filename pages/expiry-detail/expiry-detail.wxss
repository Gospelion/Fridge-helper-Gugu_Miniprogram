.bg-image {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

page {
  font-family: "SourceHanSansExtraLight", "SourceHanSansExtraLightLatin", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 200;
}

.summary-title,
.item-name,
.expiry-label,
.empty-title {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(245, 247, 250, 0.35);
}

.summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border-left: 8rpx solid #f39c12;
}

.summary.expired { border-left-color: #e74c3c; }
.summary-title { font-size: 34rpx; font-weight: 700; color: #333; }
.summary-count { font-size: 26rpx; color: #777; }
.detail-list { display: flex; flex-direction: column; gap: 20rpx; }

.detail-card {
  padding: 26rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.detail-main, .detail-meta { display: flex; justify-content: space-between; align-items: center; }
.detail-main { margin-bottom: 18rpx; }
.item-name { font-size: 32rpx; font-weight: 700; color: #333; }
.item-quantity { font-size: 28rpx; color: #555; }
.expiry-label { font-size: 25rpx; color: #f39c12; font-weight: 600; }
.expiry-label.expired { color: #e74c3c; }
.expiry-date { font-size: 23rpx; color: #999; }
.empty-state { padding-top: 180rpx; text-align: center; }
.empty-title { display: block; font-size: 34rpx; font-weight: 700; color: #555; }
.empty-desc { display: block; margin-top: 14rpx; font-size: 26rpx; color: #999; }
