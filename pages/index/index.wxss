page {
  background: #F2EBDD;
  color: #24231f;
  font-family: "SourceHanSansExtraLight", "SourceHanSansExtraLightLatin", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 200;
}

.hero-title,
.hero-summary-count,
.section-title,
.inventory-title,
.recipe-name,
.recommend-btn,
.compact-btn,
.empty-title,
.dashboard-value,
.dashboard-unit,
.search-label,
.ingredient-name,
.ingredient-expiry-text,
.ingredient-quantity,
.swipe-delete,
.empty-state-title,
.fab-btn,
.edit-modal-title,
.unit-selector-title,
.edit-label,
.edit-value,
.edit-btn-cancel,
.edit-btn-confirm {
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.paper-canvas,
.paper-texture {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.paper-canvas {
  z-index: 0;
  background: #F2EBDD;
}

.paper-texture {
  z-index: 0;
  opacity: 0.026;
}

.page {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100vh;
  padding: 0 28rpx;
  box-sizing: border-box;
}

.hero {
  min-height: 270rpx;
  padding: calc(env(safe-area-inset-top) + 112rpx) 18rpx 32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  box-sizing: border-box;
}

.hero-copy {
  position: relative;
  z-index: 2;
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  color: #24231f;
  font-size: 60rpx;
  line-height: 1.05;
  font-weight: 700;
  letter-spacing: -3rpx;
}

.hero-summary {
  margin-top: 22rpx;
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
  color: #6f695f;
  font-size: 27rpx;
  line-height: 1.45;
}

.hero-summary-count {
  color: #b95d3f;
  font-size: 31rpx;
  font-weight: 700;
}

.mascot-frame {
  width: 260rpx;
  height: 210rpx;
  margin: 0 -12rpx -28rpx 10rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 50%;
  background: #F2EBDD;
}

.mascot-image {
  width: 100%;
  height: 100%;
}

.surface-shell {
  margin-bottom: 22rpx;
  padding: 7rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.34);
  border: 1rpx solid rgba(65, 55, 43, 0.07);
  box-shadow: 0 12rpx 38rpx rgba(64, 48, 31, 0.035);
  box-sizing: border-box;
}

.surface-core {
  border-radius: 21rpx;
  background: rgba(253, 250, 244, 0.91);
  border: 1rpx solid rgba(65, 55, 43, 0.055);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
}

.recommend-card {
  padding: 24rpx;
}

.section-header,
.inventory-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title,
.inventory-title {
  color: #292722;
  font-size: 31rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.recommend-refresh {
  width: 50rpx;
  height: 50rpx;
  opacity: 0.72;
}

.recommend-list {
  display: flex;
  gap: 14rpx;
}

.recommend-settings {
  margin: -4rpx 0 18rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.setting-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(237, 232, 222, 0.8);
  color: #625c53;
  font-size: 20rpx;
  line-height: 1;
}

.reminder-setting {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #625c53;
  font-size: 20rpx;
}

.reminder-setting switch {
  transform: scale(0.68);
  transform-origin: right center;
}

.recommend-item {
  width: calc(50% - 7rpx);
  min-width: 0;
  overflow: hidden;
}

.recommend-body {
  min-height: 184rpx;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  border-radius: 15rpx;
  background: rgba(255, 255, 255, 0.48);
  border: 1rpx solid rgba(57, 50, 41, 0.075);
  box-sizing: border-box;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), opacity 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.recommend-body-hover {
  transform: scale(0.985);
  opacity: 0.78;
}

.recommend-content {
  width: 100%;
  min-width: 0;
}

.recipe-name {
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  color: #2c2924;
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-meta {
  display: block;
  overflow: hidden;
  color: #7e776d;
  font-size: 20rpx;
  line-height: 1.55;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-ingredients {
  max-width: 100%;
}

.recipe-stock {
  display: block;
  margin-top: 6rpx;
  font-size: 19rpx;
  line-height: 1.4;
}

.recipe-stock-ready {
  color: #557459;
}

.recipe-stock-missing {
  color: #b87522;
}

.recommend-actions {
  width: 100%;
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  align-items: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.recommend-btn,
.compact-btn {
  margin: 14rpx 0 0;
  padding: 0 22rpx;
  min-width: 86rpx;
  height: 54rpx;
  min-height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #292722;
  color: #fffdf8;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  box-sizing: border-box;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background-color 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.recommend-btn::after,
.compact-btn::after {
  border: 0;
}

.recommend-btn {
  width: 100% !important;
  min-width: 0 !important;
  max-width: none !important;
  margin: 0 !important;
  padding: 0 !important;
  line-height: 1 !important;
}

.favorite-btn {
  width: 100% !important;
  min-width: 0 !important;
  max-width: none !important;
  margin: 0 !important;
  padding: 0 12rpx !important;
  height: 54rpx;
  min-height: 54rpx;
  border-radius: 10rpx;
  background: transparent;
  border: 1rpx solid rgba(64, 55, 44, 0.16);
  color: #746c62;
  font-size: 19rpx;
  line-height: 52rpx;
  box-sizing: border-box;
}

.favorite-btn::after {
  border: 0;
}

.favorite-btn-active {
  background: #efe2c9;
  color: #805d27;
  border-color: rgba(128, 93, 39, 0.18);
}

.recommend-btn:active,
.compact-btn:active,
.fab-btn:active {
  transform: scale(0.97);
}

.recommend-empty {
  padding: 28rpx 12rpx 20rpx;
  text-align: center;
}

.empty-state-hover {
  opacity: 0.72;
}

.empty-title {
  display: block;
  color: #34312c;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  display: block;
  margin-top: 8rpx;
  color: #827b70;
  font-size: 24rpx;
}

.recommend-empty .compact-btn,
.empty-state .compact-btn {
  margin: 20rpx auto 0;
}

.dashboard-card {
  padding: 20rpx 10rpx;
}

.dashboard-row {
  display: flex;
  align-items: stretch;
}

.dashboard-item {
  flex: 1;
  min-width: 0;
  padding: 12rpx 4rpx;
  text-align: center;
  border-radius: 14rpx;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background-color 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.dashboard-divider {
  width: 1rpx;
  margin: 10rpx 0;
  background: rgba(65, 55, 43, 0.1);
}

.dashboard-label {
  display: block;
  color: #777066;
  font-size: 22rpx;
  line-height: 1.3;
}

.dashboard-number-row {
  margin-top: 10rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.dashboard-value {
  color: #292722;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.dashboard-unit {
  margin-left: 6rpx;
  color: inherit;
  font-size: 25rpx;
  font-weight: 600;
}

.dashboard-detail {
  display: block;
  margin-top: 7rpx;
  color: #958c80;
  font-size: 18rpx;
}

.category-distribution {
  margin: 20rpx 14rpx 4rpx;
  padding-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx 20rpx;
  border-top: 1rpx solid rgba(65, 55, 43, 0.08);
}

.category-stat-label {
  margin-bottom: 7rpx;
  display: flex;
  justify-content: space-between;
  color: #7a7268;
  font-size: 18rpx;
}

.category-stat-track {
  height: 7rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(65, 55, 43, 0.08);
}

.category-stat-fill {
  min-width: 2rpx;
  height: 100%;
  border-radius: inherit;
  background: #8da384;
}

.category-stat-fill-1 { background: #a7b98f; }
.category-stat-fill-2 { background: #c99a88; }
.category-stat-fill-3 { background: #9ba397; }

.dashboard-warning .dashboard-value,
.dashboard-warning .dashboard-unit {
  color: #b87522;
}

.dashboard-expired .dashboard-value,
.dashboard-expired .dashboard-unit {
  color: #c34f42;
}

.dashboard-link-hover {
  transform: scale(0.97);
  background: rgba(77, 67, 54, 0.04);
}

.inventory-card {
  padding: 24rpx;
}

.inventory-header {
  margin-bottom: 20rpx;
}

.inventory-count {
  color: #8b8377;
  font-size: 22rpx;
}

.search-bar {
  height: 72rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  background: rgba(237, 232, 222, 0.72);
  border: 1rpx solid rgba(64, 55, 44, 0.045);
  box-sizing: border-box;
}

.search-label {
  padding-right: 16rpx;
  margin-right: 16rpx;
  border-right: 1rpx solid rgba(65, 55, 43, 0.11);
  color: #6f685e;
  font-size: 21rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  color: #302e29;
  font-size: 25rpx;
}

.search-placeholder {
  color: #aaa195;
}

.search-clear {
  padding-left: 16rpx;
  color: #8c8277;
  font-size: 21rpx;
}

.filter-bar {
  width: 100%;
  margin: 18rpx 0 20rpx;
  white-space: nowrap;
}

.filter-content {
  display: inline-flex;
  padding-right: 6rpx;
}

.filter-tag {
  margin-right: 12rpx;
  padding: 12rpx 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border: 1rpx solid rgba(64, 55, 44, 0.09);
  color: #6f685f;
  font-size: 23rpx;
  line-height: 1;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background-color 420ms cubic-bezier(0.32, 0.72, 0, 1), color 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.filter-tag-active {
  background: #292722;
  border-color: #292722;
  color: #fffdf8;
}

.inventory-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.swipe-area {
  width: 100%;
  height: 126rpx;
  overflow: hidden;
  background: transparent;
}

.swipe-view {
  width: calc(100% + 144rpx);
  height: 126rpx;
  background: transparent;
  white-space: nowrap;
  will-change: transform;
  transform: translateZ(0);
  backface-visibility: hidden;
}

.swipe-inner {
  width: 100%;
  height: 126rpx;
  display: flex;
}

.ingredient-card {
  width: calc(100% - 144rpx);
  height: 126rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(64, 55, 44, 0.065);
  box-sizing: border-box;
  transform: translateZ(0);
  backface-visibility: hidden;
}

.bg-agri {
  background: #fbf1e4;
}

.bg-veg {
  background: #edf2e9;
}

.bg-fruit {
  background: #f7ebe8;
}

.bg-other {
  background: #eef0ea;
}

.ingredient-copy,
.ingredient-meta {
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.ingredient-copy {
  flex: 1;
  align-items: flex-start;
}

.ingredient-meta {
  margin-left: 20rpx;
  align-items: flex-end;
}

.ingredient-name {
  max-width: 360rpx;
  overflow: hidden;
  color: #2d2a25;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ingredient-expiry-text {
  display: block;
  margin-top: 15rpx;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 600;
}

.ingredient-quantity {
  color: #2b2924;
  font-size: 31rpx;
  line-height: 1.2;
  font-weight: 700;
}

.ingredient-category-tag {
  margin-top: 14rpx;
  color: #8b8378;
  font-size: 21rpx;
  line-height: 1.2;
}

.expiry-normal {
  color: #487052;
}

.expiry-warning {
  color: #9a6a20;
}

.expiry-urgent {
  color: #ad5e2f;
}

.expiry-expired {
  color: #c5483e;
}

.expiry-unset {
  color: #8d857a;
}

.swipe-delete {
  width: 144rpx;
  height: 126rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 0 16rpx 16rpx 0;
  background: #b84d44;
  color: #fffaf4;
  font-size: 25rpx;
  font-weight: 600;
}

.highlight-new {
  animation: highlight-pulse 720ms cubic-bezier(0.32, 0.72, 0, 1) 2;
}

@keyframes highlight-pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(0.985);
  }
}

.empty-state {
  padding: 42rpx 12rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-state-image {
  width: 180rpx;
  height: 180rpx;
  opacity: 0.72;
}

.empty-state-title {
  margin-top: 18rpx;
  color: #34312c;
  font-size: 29rpx;
  font-weight: 700;
}

.empty-state-desc {
  margin-top: 8rpx;
  color: #81796f;
  font-size: 23rpx;
}

.fab-wrapper {
  position: fixed;
  right: 54rpx;
  bottom: calc(env(safe-area-inset-bottom) + 142rpx);
  z-index: 21;
  width: 92rpx;
  height: 92rpx;
}

.fab-btn {
  width: 92rpx !important;
  height: 92rpx !important;
  min-width: 92rpx !important;
  min-height: 92rpx !important;
  max-width: 92rpx !important;
  max-height: 92rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #315c4b;
  color: #fffdf8;
  box-shadow: 0 14rpx 34rpx rgba(48, 63, 52, 0.16);
  font-size: 50rpx;
  font-weight: 500;
  line-height: 1 !important;
  box-sizing: border-box !important;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.fab-btn::after {
  border: 0;
}

.page-spacer {
  height: calc(env(safe-area-inset-bottom) + 180rpx);
}

.section-enter {
  animation: section-enter 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.section-delay-1 {
  animation-delay: 70ms;
}

.section-delay-2 {
  animation-delay: 140ms;
}

.section-delay-3 {
  animation-delay: 210ms;
}

@keyframes section-enter {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 100;
  visibility: hidden;
  background: rgba(38, 34, 29, 0.42);
  opacity: 0;
  transition: opacity 520ms cubic-bezier(0.32, 0.72, 0, 1), visibility 520ms cubic-bezier(0.32, 0.72, 0, 1);
}

.modal-mask.active {
  visibility: visible;
  opacity: 1;
}

.edit-modal,
.unit-selector {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 101;
  display: flex;
  flex-direction: column;
  border-radius: 34rpx 34rpx 0 0;
  background: #fbf6ed;
  border-top: 1rpx solid rgba(64, 55, 44, 0.08);
  box-shadow: 0 -20rpx 60rpx rgba(55, 44, 31, 0.08);
  transform: translateY(100%);
  transition: transform 620ms cubic-bezier(0.32, 0.72, 0, 1);
}

.edit-modal {
  max-height: 80vh;
}

.unit-selector {
  max-height: 70vh;
}

.edit-modal.active,
.unit-selector.active {
  transform: translateY(0);
}

.edit-modal-header,
.unit-selector-header {
  padding: 30rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(64, 55, 44, 0.08);
}

.edit-modal-title,
.unit-selector-title {
  color: #2d2a25;
  font-size: 32rpx;
  font-weight: 700;
}

.edit-modal-close,
.unit-selector-close {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #81796e;
}

.edit-modal-close text,
.unit-selector-close text {
  font-size: 28rpx;
}

.edit-modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.edit-item {
  margin-bottom: 28rpx;
}

.edit-label {
  display: block;
  margin-bottom: 12rpx;
  color: #746d63;
  font-size: 24rpx;
  font-weight: 500;
}

.edit-value {
  color: #2d2a25;
  font-size: 31rpx;
  font-weight: 700;
}

.edit-input,
.edit-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.48);
  border: 1rpx solid rgba(64, 55, 44, 0.08);
  color: #302d28;
  font-size: 27rpx;
  box-sizing: border-box;
}

.edit-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.edit-picker-arrow {
  color: #8f877b;
  font-size: 18rpx;
}

.edit-modal-footer {
  padding: 22rpx 32rpx calc(env(safe-area-inset-bottom) + 28rpx);
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid rgba(64, 55, 44, 0.08);
}

.edit-btn-cancel,
.edit-btn-confirm {
  flex: 1;
  height: 84rpx;
  min-height: 84rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.edit-btn-cancel {
  background: #ece5da;
  color: #696258;
}

.edit-btn-confirm {
  background: #292722;
  color: #fffdf8;
}

.edit-btn-cancel::after,
.edit-btn-confirm::after {
  border: 0;
}

.unit-grid {
  padding: 26rpx 28rpx calc(env(safe-area-inset-bottom) + 30rpx);
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  overflow-y: auto;
}

.unit-card {
  width: calc(33.333% - 10rpx);
  padding: 22rpx 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.44);
  border: 1rpx solid rgba(64, 55, 44, 0.08);
  text-align: center;
  box-sizing: border-box;
}

.unit-card.selected {
  background: #e5ece2;
  border-color: rgba(49, 92, 75, 0.28);
}

.unit-card-name {
  color: #34312c;
  font-size: 27rpx;
}
