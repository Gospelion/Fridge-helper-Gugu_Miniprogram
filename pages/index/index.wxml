<!-- 背景图层 -->
<image src="/assets/background.jpg" class="bg-image" mode="aspectFill" />

<scroll-view class="page" scroll-y="true" style="height: 100vh;">
  <!-- 今日推荐菜品 -->
  <view class="card recommend-card">
    <view class="recommend-header">
      <view class="recommend-title-wrapper">
        <text class="recommend-title">今日推荐</text>
        <text class="recommend-sub">根据你冰箱里的食材智能生成</text>
      </view>
      <image
        class="recommend-refresh"
        src="/assets/refresh.png"
        mode="aspectFit"
        bindtap="onRefreshRecommend"
      />
    </view>

    <block wx:if="{{recommendedRecipes.length > 0}}">
      <view class="recommend-list">
        <view class="recommend-item" wx:for="{{recommendedRecipes}}" wx:key="name">
          <view class="recommend-body" bindtap="onRecommendTap" data-name="{{item.name}}" data-ingredients="{{item.ingredientsStr}}" hover-class="recommend-body-hover" hover-start-time="50" hover-stay-time="100">
            <view class="recommend-content">
              <text class="recipe-name">{{item.name}}</text>
              <view class="recipe-info">
                <text class="recipe-meta">难度：{{item.difficulty}}</text>
                <text class="recipe-meta">用到：{{item.ingredientsText}}</text>
              </view>
            </view>
            <button
              class="btn-primary recommend-btn"
              data-name="{{item.name}}"
              bindtap="goDiaryWithRecipe"
            >
              记录
            </button>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="recommend-empty">
        <text class="empty-title">库存有点空啦～</text>
        <text class="empty-desc">去添加一些食材，再来看看可以做什么吧</text>
        <button class="btn-primary" size="mini" bindtap="goAddPage">去添加食材</button>
      </view>
    </block>
  </view>

  <!-- 首页数据概览看板 -->
  <view class="card dashboard-card">
    <view class="dashboard-row">
      <view class="dashboard-item">
        <text class="dashboard-label">📦 总库存数</text>
        <text class="dashboard-value">{{dashboard.total}} 件 | {{dashboard.totalTypes}} 种</text>
      </view>
      <view class="dashboard-item dashboard-warning">
        <text class="dashboard-label">⚠️ 临期警告</text>
        <text class="dashboard-value">{{dashboard.warning}} 件 | {{dashboard.warningTypes}} 种</text>
      </view>
      <view class="dashboard-item dashboard-expired">
        <text class="dashboard-label">🗑️ 已过期</text>
        <text class="dashboard-value">{{dashboard.expired}} 件 | {{dashboard.expiredTypes}} 种</text>
      </view>
    </view>
  </view>

  <!-- 库存列表（卡片流 + 顶部筛选） -->
  <view class="card inventory-card">
    <view class="inventory-header">
      <text class="inventory-title">当前库存</text>

      <!-- 搜索框 -->
      <view class="search-bar">
        <input
          class="search-input"
          placeholder="搜索食材..."
          value="{{searchKey}}"
          bindinput="onSearchInput"
          confirm-type="search"
        />
        <text wx:if="{{searchKey}}" class="search-clear" bindtap="onSearchClear">✕</text>
      </view>

      <text class="inventory-count">{{filteredInventory.length}} 种食材</text>
    </view>

    <!-- 顶部分类筛选栏 -->
    <scroll-view
      class="filter-bar"
      scroll-x="true"
      enable-flex="true"
      show-scrollbar="false"
    >
      <view class="filter-content">
        <view
          wx:for="{{categories}}"
          wx:key="*this"
          class="filter-tag {{activeCategory === item ? 'filter-tag-active' : ''}}"
          data-name="{{item}}"
          bindtap="onFilterTap"
        >
          <text class="filter-tag-text">{{item}}</text>
        </view>
      </view>
    </scroll-view>

    <block wx:if="{{filteredInventory.length}}">
      <view class="inventory-list">
        <block wx:for="{{filteredInventory}}" wx:key="id">
          <!-- 
            movable-area: 可视窗口，宽度必须固定为屏幕宽 
            不要在这里设 width: 100%，最好由 CSS 控制
          -->
          <movable-area class="swipe-area">
            <movable-view
              class="swipe-view"
              direction="horizontal"
              damping="20"
              friction="2"
              speed="2"
              inertia="true"
              out-of-bounds="true"
              x="{{swipeOffsets[item.id] || 0}}"
              data-id="{{item.id}}"
              bindchange="onItemSwipeChange"
              bindtouchend="onItemSwipeEnd"
            >
              <!-- 
                swipe-inner: 承载 [卡片] + [删除按钮] 
                它的宽度会自动撑开 movable-view
              -->
              <view class="swipe-inner">
                
                <!-- 左侧：食材卡片 -->
                <view
                  class="ingredient-card {{item.categoryBgClass}} {{item.isNewlyAdded ? 'highlight-new' : ''}}"
                  bindtap="onInventoryTap"
                  bindlongpress="onInventoryLongPress"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                  data-quantity="{{item.quantity}}"
                >
                  <view class="ingredient-header">
                    <text class="ingredient-name">{{item.name}}</text>
                    <text class="ingredient-quantity">{{item.quantity}}{{item.unit}}</text>
                  </view>
                  <view class="ingredient-footer">
                    <view class="ingredient-expiry">
                      <text class="ingredient-expiry-text {{item.expiryStatusClass}}">
                        {{item.expiryLabel}}
                      </text>
                    </view>
                    <text class="ingredient-category-tag">{{item.category}}</text>
                  </view>
                </view>

                <!-- 右侧：红色删除按钮 -->
                <view
                  class="swipe-delete"
                  bindtap="onSwipeDeleteTap"
                  data-id="{{item.id}}"
                  data-name="{{item.name}}"
                >
                  删除
                </view>
                
              </view>
            </movable-view>
          </movable-area>
        </block>
      </view>
    </block>

    <block wx:else>
      <view class="empty-state">
        <image
          class="empty-state-image"
          src="/assets/empty-fridge.png"
          mode="aspectFit"
        ></image>
        <text class="empty-state-title">{{searchKey ? '没有找到匹配的食材' : '冰箱还是空的'}}</text>
        <text class="empty-state-desc">{{searchKey ? '试试其他关键词吧' : '开始添加第一批食材吧'}}</text>
        <button wx:if="{{searchKey}}" class="btn-primary" size="mini" bindtap="onSearchClear">清除搜索</button>
      </view>
    </block>
  </view>

  <!-- 底部添加食材悬浮按钮 -->
  <view class="fab-wrapper">
    <button class="fab-btn" bindtap="goAddPage">+</button>
  </view>
</scroll-view>

<!-- 编辑食材模态框 -->
<view class="modal-mask {{showEditModal ? 'active' : ''}}" bindtap="closeEditModal"></view>
<view class="edit-modal {{showEditModal ? 'active' : ''}}">
  <view class="edit-modal-header">
    <text class="edit-modal-title">编辑食材</text>
    <view class="edit-modal-close" bindtap="closeEditModal">
      <text>✕</text>
    </view>
  </view>

  <view class="edit-modal-body">
    <!-- 食材名称（不可编辑） -->
    <view class="edit-item">
      <text class="edit-label">食材名称</text>
      <text class="edit-value">{{editForm.name}}</text>
    </view>

    <!-- 数量 -->
    <view class="edit-item">
      <text class="edit-label">数量</text>
      <input
        class="edit-input"
        type="number"
        placeholder="请输入数量"
        value="{{editForm.quantity}}"
        bindinput="onEditQuantityInput"
      />
    </view>

    <!-- 单位 -->
    <view class="edit-item">
      <text class="edit-label">单位</text>
      <view class="edit-picker" bindtap="openEditUnitSelector">
        <text>{{units[editForm.unitIndex]}}</text>
        <text class="edit-picker-arrow">▼</text>
      </view>
    </view>

    <!-- 距离过期天数 -->
    <view class="edit-item">
      <text class="edit-label">距离过期（天）</text>
      <input
        class="edit-input"
        type="number"
        placeholder="请输入天数"
        value="{{editForm.expiryDays}}"
        bindinput="onEditExpiryDaysInput"
      />
    </view>
  </view>

  <view class="edit-modal-footer">
    <button class="edit-btn-cancel" bindtap="closeEditModal">取消</button>
    <button class="edit-btn-confirm" bindtap="confirmEdit">保存</button>
  </view>
</view>

<!-- 单位选择器（编辑用） -->
<view class="modal-mask {{showEditUnitSelector ? 'active' : ''}}" bindtap="closeEditUnitSelector"></view>
<view class="unit-selector {{showEditUnitSelector ? 'active' : ''}}">
  <view class="unit-selector-header">
    <text class="unit-selector-title">选择单位</text>
    <view class="unit-selector-close" bindtap="closeEditUnitSelector">
      <text>✕</text>
    </view>
  </view>
  <view class="unit-grid">
    <block wx:for="{{units}}" wx:key="*this">
      <view
        class="unit-card {{editForm.unitIndex === index ? 'selected' : ''}}"
        bindtap="onEditUnitCardTap"
        data-index="{{index}}"
      >
        <text class="unit-card-name">{{item}}</text>
      </view>
    </block>
  </view>
</view>
