<view class="paper-canvas"></view>
<image src="/assets/background.jpg" class="paper-texture" mode="aspectFill" />

<scroll-view class="page" scroll-y="true" enhanced="true" show-scrollbar="false">
  <view class="hero section-enter">
    <view class="hero-copy">
      <text class="hero-title">冰箱库存</text>
      <view class="hero-summary">
        <text>今天先处理</text>
        <text class="hero-summary-count">{{dashboard.expired}} 件</text>
        <text>过期食材</text>
      </view>
    </view>
    <view class="mascot-frame">
      <image src="/assets/hero-mascot.png" class="mascot-image" mode="aspectFill" />
    </view>
  </view>

  <view class="surface-shell recommend-shell section-enter section-delay-1">
    <view class="surface-core recommend-card">
      <view class="section-header">
        <text class="section-title">今日推荐</text>
        <image class="recommend-refresh" src="/assets/refresh.png" mode="aspectFit" bindtap="onRefreshRecommend" />
      </view>

      <block wx:if="{{recommendedRecipes.length > 0}}">
        <view class="recommend-list">
          <view class="recommend-item" wx:for="{{recommendedRecipes}}" wx:key="name">
            <view
              class="recommend-body"
              bindtap="onRecommendTap"
              data-name="{{item.name}}"
              data-ingredients="{{item.ingredientsStr}}"
              hover-class="recommend-body-hover"
            >
              <view class="recommend-content">
                <text class="recipe-name">{{item.name}}</text>
                <text class="recipe-meta">难度：{{item.difficulty}}</text>
                <text class="recipe-meta recipe-ingredients">用到：{{item.ingredientsText}}</text>
              </view>
              <button class="recommend-btn" data-name="{{item.name}}" catchtap="goDiaryWithRecipe">记录</button>
            </view>
          </view>
        </view>
      </block>

      <view wx:else class="recommend-empty" bindtap="goAddPage" hover-class="empty-state-hover">
        <text class="empty-title">库存有点空</text>
        <text class="empty-desc">添加食材后，就能生成今日推荐</text>
        <button class="compact-btn">添加食材</button>
      </view>
    </view>
  </view>

  <view class="surface-shell dashboard-shell section-enter section-delay-2">
    <view class="surface-core dashboard-card">
      <view class="dashboard-row">
        <view class="dashboard-item">
          <text class="dashboard-label">总库存</text>
          <view class="dashboard-number-row">
            <text class="dashboard-value">{{dashboard.total}}</text><text class="dashboard-unit">件</text>
          </view>
        </view>
        <view class="dashboard-divider"></view>
        <view class="dashboard-item dashboard-warning dashboard-link" bindtap="goExpiryDetail" data-type="warning" hover-class="dashboard-link-hover">
          <text class="dashboard-label">临期</text>
          <view class="dashboard-number-row">
            <text class="dashboard-value">{{dashboard.warning}}</text><text class="dashboard-unit">件</text>
          </view>
        </view>
        <view class="dashboard-divider"></view>
        <view class="dashboard-item dashboard-expired dashboard-link" bindtap="goExpiryDetail" data-type="expired" hover-class="dashboard-link-hover">
          <text class="dashboard-label">已过期</text>
          <view class="dashboard-number-row">
            <text class="dashboard-value">{{dashboard.expired}}</text><text class="dashboard-unit">件</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="surface-shell inventory-shell section-enter section-delay-3">
    <view class="surface-core inventory-card">
      <view class="inventory-header">
        <text class="inventory-title">当前库存</text>
        <text class="inventory-count">{{filteredInventory.length}} 种食材</text>
      </view>

      <view class="search-bar">
        <text class="search-label">搜索</text>
        <input
          class="search-input"
          placeholder="搜索食材"
          placeholder-class="search-placeholder"
          value="{{searchKey}}"
          bindinput="onSearchInput"
          confirm-type="search"
        />
        <text wx:if="{{searchKey}}" class="search-clear" bindtap="onSearchClear">清除</text>
      </view>

      <scroll-view class="filter-bar" scroll-x="true" enable-flex="true" show-scrollbar="false">
        <view class="filter-content">
          <view
            wx:for="{{categories}}"
            wx:key="*this"
            class="filter-tag {{activeCategory === item ? 'filter-tag-active' : ''}}"
            data-name="{{item}}"
            bindtap="onFilterTap"
          >
            <text>{{item}}</text>
          </view>
        </view>
      </scroll-view>

      <block wx:if="{{filteredInventory.length}}">
        <view class="inventory-list">
          <block wx:for="{{filteredInventory}}" wx:key="id">
            <movable-area class="swipe-area">
              <movable-view
                class="swipe-view"
                direction="horizontal"
                damping="20"
                friction="2"
                speed="2"
                inertia="true"
                out-of-bounds="true"
                x="{{swipeOffsets[item.id] || 0}}"
                data-id="{{item.id}}"
                bindchange="onItemSwipeChange"
                bindtouchend="onItemSwipeEnd"
              >
                <view class="swipe-inner">
                  <view
                    class="ingredient-card {{item.categoryBgClass}} {{item.isNewlyAdded ? 'highlight-new' : ''}}"
                    bindtap="onInventoryTap"
                    bindlongpress="onInventoryLongPress"
                    data-id="{{item.id}}"
                    data-name="{{item.name}}"
                    data-quantity="{{item.quantity}}"
                    data-unit="{{item.unit}}"
                  >
                    <view class="ingredient-copy">
                      <text class="ingredient-name">{{item.name}}</text>
                      <text class="ingredient-expiry-text {{item.expiryStatusClass}}">{{item.expiryLabel}}</text>
                    </view>
                    <view class="ingredient-meta">
                      <text class="ingredient-quantity">{{item.quantity}}{{item.unit}}</text>
                      <text class="ingredient-category-tag">{{item.category}}</text>
                    </view>
                  </view>
                  <view class="swipe-delete" bindtap="onSwipeDeleteTap" data-id="{{item.id}}" data-name="{{item.name}}">删除</view>
                </view>
              </movable-view>
            </movable-area>
          </block>
        </view>
      </block>

      <view wx:else class="empty-state">
        <image class="empty-state-image" src="/assets/empty-fridge.png" mode="aspectFit" />
        <text class="empty-state-title">{{searchKey ? '没有找到匹配的食材' : '冰箱还是空的'}}</text>
        <text class="empty-state-desc">{{searchKey ? '换个关键词试试' : '添加第一批食材，开始管理库存'}}</text>
        <button wx:if="{{searchKey}}" class="compact-btn" bindtap="onSearchClear">清除搜索</button>
      </view>
    </view>
  </view>

  <view class="page-spacer"></view>
</scroll-view>

<view class="fab-wrapper">
  <button class="fab-btn" bindtap="goAddPage">+</button>
</view>

<!-- 编辑食材模态框 -->
<view class="modal-mask {{showEditModal ? 'active' : ''}}" bindtap="closeEditModal"></view>
<view class="edit-modal {{showEditModal ? 'active' : ''}}">
  <view class="edit-modal-header">
    <text class="edit-modal-title">编辑食材</text>
    <view class="edit-modal-close" bindtap="closeEditModal">
      <text>✕</text>
    </view>
  </view>

  <view class="edit-modal-body">
    <!-- 食材名称（不可编辑） -->
    <view class="edit-item">
      <text class="edit-label">食材名称</text>
      <text class="edit-value">{{editForm.name}}</text>
    </view>

    <!-- 数量 -->
    <view class="edit-item">
      <text class="edit-label">数量</text>
      <input
        class="edit-input"
        type="number"
        placeholder="请输入数量"
        value="{{editForm.quantity}}"
        bindinput="onEditQuantityInput"
        cursor-spacing="24"
      />
    </view>

    <!-- 单位 -->
    <view class="edit-item">
      <text class="edit-label">单位</text>
      <view class="edit-picker" bindtap="openEditUnitSelector">
        <text>{{units[editForm.unitIndex]}}</text>
        <text class="edit-picker-arrow">▼</text>
      </view>
    </view>

    <!-- 距离过期天数 -->
    <view class="edit-item">
      <text class="edit-label">距离过期（天）</text>
      <input
        class="edit-input"
        type="number"
        placeholder="请输入天数"
        value="{{editForm.expiryDays}}"
        bindinput="onEditExpiryDaysInput"
        cursor-spacing="24"
      />
    </view>
  </view>

  <view class="edit-modal-footer">
    <button class="edit-btn-cancel" bindtap="closeEditModal">取消</button>
    <button class="edit-btn-confirm" bindtap="confirmEdit">保存</button>
  </view>
</view>

<!-- 单位选择器（编辑用） -->
<view class="modal-mask {{showEditUnitSelector ? 'active' : ''}}" bindtap="closeEditUnitSelector"></view>
<view class="unit-selector {{showEditUnitSelector ? 'active' : ''}}">
  <view class="unit-selector-header">
    <text class="unit-selector-title">选择单位</text>
    <view class="unit-selector-close" bindtap="closeEditUnitSelector">
      <text>✕</text>
    </view>
  </view>
  <view class="unit-grid">
    <block wx:for="{{units}}" wx:key="*this">
      <view
        class="unit-card {{editForm.unitIndex === index ? 'selected' : ''}}"
        bindtap="onEditUnitCardTap"
        data-index="{{index}}"
      >
        <text class="unit-card-name">{{item}}</text>
      </view>
    </block>
  </view>
</view>
