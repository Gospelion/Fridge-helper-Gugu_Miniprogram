.bg-image {
  position: fixed; /* 固定定位，覆盖整个屏幕 */
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1; /* 确保它在内容下方 */
  pointer-events: none; /* 防止阻挡点击事件 */
}

.page {
  padding: 24rpx;
  
  min-height: 100vh;
  box-sizing: border-box;
}

/* 通用卡片容器 */
.card {
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-card {
  margin-bottom: 24rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.section-sub {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999999;
}

.ocr-btn {
  margin-top: 8rpx;
}

/* 识别结果显示 */
.recognized-result {
  margin-top: 16rpx;
  padding: 16rpx;
  background-color: #f0f7ff;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
  border-left: 4rpx solid #4caf50;
}

.hint-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #bbbbbb;
}

/* 快捷标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.tag {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e0e0e0;
  font-size: 24rpx;
  color: #555555;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

/* 表单 */
.form {
  margin-top: 8rpx;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.form-label-row .form-label {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #555555;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.form-hint {
  font-size: 22rpx;
  color: #999999;
  margin-left: 1em;
}

.form-hint-bold {
  font-weight: bold;
}

.form-input {
  background-color: #f7f7f7;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
}

.picker {
  background-color: #f7f7f7;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #333333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* Picker 箭头 */
.picker-arrow {
  font-size: 20rpx;
  color: #999999;
  margin-left: 10rpx;
}

/* 模态框遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.modal-mask.active {
  opacity: 1;
  visibility: visible;
}

/* 单位选择器 */
.unit-selector {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.unit-selector.active {
  transform: translateY(0);
}

.recognition-review {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  max-height: 75vh;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.25s ease;
}

.recognition-review.active { transform: translateY(0); }
.review-subtitle { display: block; margin-top: 6rpx; color: #999; font-size: 24rpx; }
.review-list { max-height: 48vh; padding: 0 32rpx; box-sizing: border-box; }
.review-row { display: flex; gap: 12rpx; align-items: center; padding: 18rpx 0; border-bottom: 1rpx solid #eee; }
.review-name, .review-quantity, .review-unit { padding: 14rpx; background: #f7f7f7; border-radius: 10rpx; font-size: 26rpx; }
.review-name { flex: 1; min-width: 0; }
.review-quantity { width: 100rpx; }
.review-unit { min-width: 80rpx; }
.review-remove { color: #d9534f; font-size: 24rpx; }
.review-actions { display: flex; gap: 20rpx; padding: 24rpx 32rpx; }
.review-actions button { flex: 1; }
.review-cancel { background: #f2f2f2; color: #555; }

.unit-selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.unit-selector-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.unit-selector-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.unit-selector-close text {
  font-size: 32rpx;
  color: #999999;
}

/* 单位网格 */
.unit-grid {
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.unit-card {
  width: calc(33.33% - 12rpx);
  background-color: #f7f7f7;
  border-radius: 12rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.unit-card.selected {
  background-color: #e8f5e9;
  border-color: #4caf50;
}

.unit-card-name {
  font-size: 28rpx;
  color: #333333;
}

.submit-btn {
  margin-top: 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #000000;
}
