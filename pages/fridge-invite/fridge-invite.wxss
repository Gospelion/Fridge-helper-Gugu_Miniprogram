page { background: #F2EBDD; color: #292722; }
.page { min-height: 100vh; padding: calc(env(safe-area-inset-top) + 90rpx) 34rpx 60rpx; box-sizing: border-box; }
.invite-card { padding: 44rpx 36rpx; border-radius: 28rpx; background: rgba(253,250,244,.94); border: 1rpx solid rgba(65,55,43,.07); box-shadow: 0 18rpx 54rpx rgba(64,48,31,.06); }
.status-label { display: block; color: #9a8f80; font-size: 18rpx; letter-spacing: 4rpx; }
.fridge-name, .status-title { display: block; margin-top: 18rpx; font-size: 46rpx; line-height: 1.2; font-weight: 700; }
.status-desc { display: block; margin-top: 20rpx; color: #756d63; font-size: 25rpx; line-height: 1.7; }
.field { margin-top: 42rpx; }
.field-label { display: block; margin-bottom: 12rpx; color: #635c53; font-size: 22rpx; }
.field-input { height: 86rpx; padding: 0 22rpx; border-radius: 15rpx; background: #eee9df; color: #292722; font-size: 26rpx; box-sizing: border-box; }
.primary-button, .secondary-button { width: 100%; height: 82rpx; margin: 30rpx 0 0; display: flex; align-items: center; justify-content: center; border-radius: 14rpx; font-size: 24rpx; line-height: 1; }
.primary-button { background: #292722; color: #fffdf8; }
.secondary-button { background: #e9e3d8; color: #5f584f; }
.primary-button::after, .secondary-button::after { border: 0; }
.privacy-note { display: block; margin-top: 20rpx; color: #999084; font-size: 19rpx; line-height: 1.6; text-align: center; }
