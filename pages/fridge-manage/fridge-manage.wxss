page { background: #F2EBDD; color: #292722; }
.page { padding: 0 28rpx; }
.hero { padding: calc(env(safe-area-inset-top) + 54rpx) 12rpx 34rpx; }
.eyebrow { display: block; color: #9a8f80; font-size: 18rpx; letter-spacing: 4rpx; }
.title { display: block; margin-top: 12rpx; font-size: 54rpx; font-weight: 700; }
.subtitle { display: block; margin-top: 14rpx; color: #766f65; font-size: 24rpx; }
.card { margin-bottom: 22rpx; padding: 26rpx; border-radius: 24rpx; background: rgba(253,250,244,.92); border: 1rpx solid rgba(65,55,43,.07); }
.section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.section-title { font-size: 30rpx; font-weight: 700; }
.section-note { display: block; margin: 10rpx 0 18rpx; color: #81786d; font-size: 21rpx; }
.text-button { margin: 0; padding: 0; background: transparent; color: #776b5e; font-size: 21rpx; line-height: 1; }
.text-button::after, .primary-button::after, .secondary-button::after, .danger-button::after, .conflict-actions button::after { border: 0; }
.fridge-row, .member-row { min-height: 96rpx; padding: 16rpx 0; display: flex; align-items: center; border-bottom: 1rpx solid rgba(65,55,43,.08); box-sizing: border-box; }
.fridge-row:last-child, .member-row:last-child { border-bottom: 0; }
.fridge-row.active { color: #4f6b53; }
.row-title { display: block; font-size: 26rpx; font-weight: 600; }
.row-meta { display: block; margin-top: 7rpx; color: #91877b; font-size: 20rpx; }
.row-state { margin-left: auto; color: #887d70; font-size: 20rpx; }
.avatar { width: 66rpx; height: 66rpx; margin-right: 18rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; background: #e6eadf; color: #536957; font-size: 25rpx; font-weight: 700; }
.member-copy { flex: 1; }
.actions { margin-top: 24rpx; display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
.primary-button, .secondary-button, .danger-button { margin: 0; height: 72rpx; display: flex; align-items: center; justify-content: center; border-radius: 13rpx; font-size: 22rpx; line-height: 1; }
.primary-button { background: #292722; color: #fffdf8; }
.secondary-button { background: #eee8dc; color: #5f584f; }
.danger-button { width: 100%; margin-top: 18rpx; background: transparent; color: #a24f42; border: 1rpx solid rgba(162,79,66,.2); }
.conflict-row { padding: 18rpx 0; border-top: 1rpx solid rgba(65,55,43,.08); }
.conflict-error { display: block; margin-top: 8rpx; color: #a24f42; font-size: 20rpx; }
.conflict-actions { margin-top: 12rpx; display: flex; gap: 10rpx; }
.conflict-actions button { flex: 1; margin: 0; height: 60rpx; background: #eee8dc; color: #615950; font-size: 20rpx; line-height: 60rpx; }
.bottom-space { height: 80rpx; }
