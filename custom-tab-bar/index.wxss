.tab-bar-stage {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  height: calc(132rpx + env(safe-area-inset-bottom));
  padding: 0 52rpx calc(12rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-end;
  box-sizing: border-box;
  pointer-events: none;
}

.tab-bar {
  width: 100%;
  height: 112rpx;
  display: flex;
  overflow: hidden;
  border-radius: 28rpx;
  background: rgba(253, 249, 241, 0.96);
  border: 1rpx solid rgba(79, 64, 47, 0.09);
  box-shadow: 0 12rpx 36rpx rgba(61, 48, 34, 0.07), inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
  pointer-events: auto;
}

.tab-bar-item {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), opacity 420ms cubic-bezier(0.32, 0.72, 0, 1);
}

.tab-bar-item-hover {
  transform: scale(0.98);
  opacity: 0.78;
}

.tab-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.tab-icon {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
}

.tab-text {
  color: #8b7661;
  font-size: 29rpx;
  line-height: 1;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.tab-bar-item.active .tab-text {
  color: #315c4b;
  font-weight: 650;
}

.active-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 58rpx;
  height: 6rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #315c4b;
  transform: translateX(-50%);
}
